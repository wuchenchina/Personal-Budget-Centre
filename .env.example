APP_ENV=production
APP_KEY=
APP_URL=https://budget.example.com
API_URL=https://budget.example.com

DB_HOST=172.17.0.1
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

SESSION_COOKIE=budgetcentre_session
CSRF_COOKIE=budgetcentre_csrf
BANK_REFERENCE_RATES_URL=

WEBAUTHN_RP_ID=budget.example.com
WEBAUTHN_RP_NAME=BudgetCentre
WEBAUTHN_ORIGIN=https://budget.example.com

CASDOOR_SERVER_URL=
CASDOOR_DISPLAY_NAME=Axchen SSO
CASDOOR_CLIENT_ID=
CASDOOR_REDIRECT_URI=https://budget.example.com/api/callback
CASDOOR_CLIENT_SECRET=

LINUX_DO_DISPLAY_NAME=Linux Do
LINUX_DO_CLIENT_ID=
LINUX_DO_CLIENT_SECRET=
LINUX_DO_AUTHORIZATION_ENDPOINT=https://connect.linux.do/oauth2/authorize
LINUX_DO_TOKEN_ENDPOINT=https://connect.linux.do/oauth2/token
LINUX_DO_USER_ENDPOINT=https://connect.linux.do/api/user
LINUX_DO_REDIRECT_URI=https://budget.example.com/api/callback
LINUX_DO_SCOPE=openid profile email

SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=BudgetCentre

WEB_BIND=127.0.0.1:18080
APP_STORAGE_ROOT=./storage

PDF_RENDERER_MIN_WORKERS=1
PDF_RENDERER_MAX_WORKERS=4
PDF_RENDERER_BATCH_SIZE=1000
PDF_RENDERER_LARGE_ROW_THRESHOLD=100000
PDF_RENDERER_LARGE_JOB_CONCURRENCY=2
PDF_RENDERER_POLL_MS=100
PDF_RENDERER_LOCK_TIMEOUT_SECONDS=300
PDF_RENDERER_JOB_SECRET=
PDF_EXPORT_TMP_MAX_AGE_HOURS=24
PDF_EXPORT_FAILED_MAX_AGE_DAYS=14
PDF_EXPORT_MAX_TOTAL_BYTES=0

# Optional runtime proxy for server-side HTTP calls such as OAuth token/userinfo.
# RUNTIME_PROXY accepts host:port, http://host:port, socks5://host:port, or sock5://host:port.
# Example: RUNTIME_PROXY=10.0.0.1:7890
RUNTIME_PROXY=
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,api,web,pdf-renderer,db

# Optional Docker build proxy. Leave blank for normal builds.
# BUILD_PROXY accepts host:port, http://host:port, socks5://host:port, or sock5://host:port.
# Example: BUILD_PROXY=10.0.0.1:7890
BUILD_PROXY=
BUILD_HTTP_PROXY=
BUILD_HTTPS_PROXY=
BUILD_ALL_PROXY=
BUILD_NO_PROXY=localhost,127.0.0.1,::1

# Docker build targets. deploy.sh uploads local prebuilt artifacts for these targets.
WEB_BUILD_TARGET=web-prebuilt
API_BUILD_TARGET=api-prebuilt
