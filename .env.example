APP_ENV=production
APP_KEY=
APP_URL=https://budget.example.com
API_URL=https://budget.example.com

DB_HOST=172.17.0.1
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

SESSION_COOKIE=budgetcentre_session
CSRF_COOKIE=budgetcentre_csrf

WEBAUTHN_RP_ID=budget.example.com
WEBAUTHN_RP_NAME=BudgetCentre
WEBAUTHN_ORIGIN=https://budget.example.com

CASDOOR_SERVER_URL=
CASDOOR_CLIENT_ID=
CASDOOR_REDIRECT_URI=https://budget.example.com/api/callback
CASDOOR_CLIENT_SECRET=

SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=BudgetCentre

WEB_BIND=127.0.0.1:18080
APP_STORAGE_ROOT=./storage

# Optional Docker build proxy. Leave blank for normal builds.
# BUILD_PROXY accepts host:port, http://host:port, socks5://host:port, or sock5://host:port.
# Example: BUILD_PROXY=10.0.0.1:7890
BUILD_PROXY=
BUILD_HTTP_PROXY=
BUILD_HTTPS_PROXY=
BUILD_ALL_PROXY=
BUILD_NO_PROXY=localhost,127.0.0.1,::1

# Docker build targets. deploy.sh uploads local prebuilt artifacts for these targets.
WEB_BUILD_TARGET=web-prebuilt
API_BUILD_TARGET=api-prebuilt
