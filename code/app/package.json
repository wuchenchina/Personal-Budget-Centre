{
  "name": "budgetcentre-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "BudgetCentre macOS desktop application",
  "main": "dist/main.js",
  "scripts": {
    "build": "yarn icon && yarn compile",
    "check": "tsc -p tsconfig.json --noEmit",
    "compile": "tsc -p tsconfig.json",
    "icon": "node scripts/create-icon.mjs",
    "start": "yarn build && electron .",
    "test": "yarn compile && node --test tests/*.test.cjs",
    "package:mac-arm64": "yarn build && electron-builder --mac dmg --arm64"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "typescript": "~6.0.2"
  },
  "build": {
    "appId": "top.axchen.budgetcentre",
    "productName": "BudgetCentre",
    "asar": true,
    "afterPack": "scripts/after-pack.cjs",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.finance",
      "icon": "build/icon.icns",
      "identity": null,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
